# ============================================
# Contextual Identity Fusion Engine — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# --- Redis Configuration ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- PostgreSQL Configuration ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cife_db
POSTGRES_USER=cife_user
POSTGRES_PASSWORD=changeme_strong_password

# --- FastAPI Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- ML Worker Configuration ---
WORKER_BATCH_SIZE=50
WORKER_POLL_INTERVAL_MS=500
EWMA_ALPHA=0.1
BASELINE_MIN_SESSIONS=3

# --- Risk Policy Thresholds ---
RISK_LOW_MAX=34
RISK_MODERATE_MAX=54
RISK_HIGH_MAX=74
# Anything above RISK_HIGH_MAX is CRITICAL

# --- Telemetry Configuration ---
TELEMETRY_PASSIVE_INTERVAL_SEC=30
TELEMETRY_RATE_LIMIT_PER_MIN=60

# --- Streamlit Dashboard ---
STREAMLIT_PORT=8501
